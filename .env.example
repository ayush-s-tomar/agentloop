# Copy this file to .env and fill in your own keys.
# Both are free to obtain.

# Groq (LLM) — get a free key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Tavily (web search tool) — get a free key at https://app.tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# Optional — override the default model
GROQ_MODEL=llama-3.3-70b-versatile

# Optional — caps to keep runs bounded
MAX_SUBQUESTIONS=4
MAX_REFLECT_ITERATIONS=2
